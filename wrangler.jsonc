{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "svelte-klaro",
    "main": ".svelte-kit/cloudflare/_worker.js",
    "compatibility_date": "2026-01-20",
    "observability": {
        "enabled": true
    },
    "assets": {
        "binding": "ASSETS",
        "directory": ".svelte-kit/cloudflare"
    }
}
