{
    "name": "svelte-klaro",
    "version": "0.1.0",
    "description": "Svelte 5 cookie consent manager — a complete port of Klaro with reactive state, tree-shakeable translations, and CSS custom property theming.",
    "license": "MIT",
    "keywords": [
        "svelte",
        "sveltekit",
        "cookie",
        "consent",
        "privacy",
        "gdpr",
        "klaro",
        "cookie-banner",
        "cookie-consent",
        "ePrivacy",
        "consent-manager",
        "i18n"
    ],
    "homepage": "https://github.com/Kage0x3B/svelte-klaro#readme",
    "bugs": "https://github.com/Kage0x3B/svelte-klaro/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Kage0x3B/svelte-klaro.git"
    },
    "author": {
        "name": "Moritz Hein",
        "email": "moritz.hein@live.de",
        "url": "https://moritz.website"
    },
    "scripts": {
        "dev": "vite dev",
        "build": "vite build && pnpm package",
        "preview": "vite preview",
        "package": "svelte-kit sync && svelte-package && pnpm package:css && publint",
        "package:css": "sass src/lib/scss/klaro.scss dist/klaro.css --no-source-map --style=compressed",
        "prepublishOnly": "pnpm package",
        "test": "pnpm test:integration && pnpm test:unit",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write .",
        "test:integration": "playwright test",
        "test:unit": "vitest"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js"
        },
        "./translations": {
            "types": "./dist/klaro/translations/index.d.ts",
            "import": "./dist/klaro/translations/index.js"
        },
        "./styles": "./dist/klaro.css",
        "./styles/scss": "./dist/scss/klaro.scss"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "peerDependencies": {
        "svelte": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.16.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "publint": "^0.3.18",
        "sass": "^1.98.0",
        "svelte": "^5.55.0",
        "svelte-check": "^4.4.5",
        "tslib": "^2.8.1",
        "typescript": "^5.8.3",
        "typescript-eslint": "8.57.1",
        "vite": "^8.0.2",
        "vitest": "^4.1.1",
        "wrangler": "^4.77.0"
    },
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "engines": {
        "node": ">=18"
    }
}
